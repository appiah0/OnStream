<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'>
  <rect width='180' height='180' rx='32' fill='#0a0a0f'/>
  <rect width='180' height='180' rx='32' fill='url(#grad)'/>
  <defs>
    <radialGradient id='glow' cx='50%' cy='45%' r='45%'>
      <stop offset='0%' stop-color='#e50914' stop-opacity='0.2'/>
      <stop offset='100%' stop-color='#e50914' stop-opacity='0'/>
    </radialGradient>
    <linearGradient id='grad' x1='0%' y1='0%' x2='100%' y2='100%'>
      <stop offset='0%' stop-color='#180808'/>
      <stop offset='100%' stop-color='#0a0a14'/>
    </linearGradient>
  </defs>
  <rect width='180' height='180' rx='32' fill='url(#glow)'/>
  <polygon points='65,53 65,127 127,90' fill='#e50914'/>
  <text x='90' y='151' font-family='Arial Black,Impact,sans-serif' font-size='20' font-weight='900' fill='white' text-anchor='middle' letter-spacing='2'>ON</text>
  <text x='90' y='171' font-family='Arial Black,Impact,sans-serif' font-size='14' font-weight='900' fill='#e50914' text-anchor='middle' letter-spacing='1'>STREAM</text>
